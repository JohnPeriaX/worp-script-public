PlayerLogout(playerid){
	if(!LoggedIn[playerid]) return Kick(playerid);
	if(AccountData[playerid][uSQLID] == 0) return Kick(playerid);
	if(PlayerData[playerid][pGasPump] != -1) return ErrorMsg(playerid, "¤ŘłäÁčĘŇÁŇĂ¶ Logout ˘łĐŕµÔÁąéÓÁŃąä´é");

	new str[128];
	format(str, sizeof(str), "%s ÍÍˇ¨ŇˇĂĐşş", ReturnName(playerid));
	SendNearbyMessage(playerid, 30.0, COLOR_GRAY, str);
	SendAdminsMessage(1, COLOR_GRAY, str);

	//PlayerLeaveParty(playerid);

	if(PlayerEnterWarCity[playerid] > 0){

		if(gangHoldingWarLSBy == playerid){
            SendClientMessageToAllEx(COLOR_RED, "[WAR-LS]: '%s' ¨Ňˇáˇę§ '%s' ·ŐčˇÓĹŃ§ÂÖ´ÇÍŕÁ×Í§ 'LS' ÍÂŮčä´éµŇÂáĹéÇ·ÓăËéˇŇĂÂÖ´ÇÍŕÁ×Í§¶ŮˇÂˇŕĹÔˇ", ReturnRoleplayName(playerid), GetGroupName(PlayerData[playerid][pGroup]));
            gangHoldingWarLSBy = INVALID_PLAYER_ID;
            gangHoldingWarLS_Time = 0;
            gangHoldingWarLS = -1;
        }

        if(gangHoldingWarSFBy == playerid){
            SendClientMessageToAllEx(COLOR_RED, "[WAR-SF]: '%s' ¨Ňˇáˇę§ '%s' ·ŐčˇÓĹŃ§ÂÖ´ÇÍŕÁ×Í§ 'SF' ÍÂŮčä´éµŇÂáĹéÇ·ÓăËéˇŇĂÂÖ´ÇÍŕÁ×Í§¶ŮˇÂˇŕĹÔˇ", ReturnRoleplayName(playerid), GetGroupName(PlayerData[playerid][pGroup]));
            gangHoldingWarSFBy = INVALID_PLAYER_ID;
            gangHoldingWarSF_Time = 0;
            gangHoldingWarSF = -1;
        }

        PlayerEnterWarCity[playerid] = 0;
        SetPlayerPos(playerid, PlayerLastPositionWarCity[playerid][0], PlayerLastPositionWarCity[playerid][1], PlayerLastPositionWarCity[playerid][2]);
        SetPlayerFacingAngle(playerid, PlayerLastPositionWarCity[playerid][3]);
        SetPlayerInterior(playerid, PlayerLastIntWarCity[playerid]);
        SetPlayerVirtualWorld(playerid, PlayerLastWorldWarCity[playerid]);
        TogglePlayerControllable(playerid, 1);
    }

	PlayerData[playerid][pSavePow] = 0;
	ResetGasPump(playerid);
	Character_Save(playerid);

	SetPlayerInterior(playerid, 0);
	SetPlayerVirtualWorld(playerid, 0);

	if(PlayerData[playerid][pCallLine] != INVALID_PLAYER_ID){
		callcmd::hangup(playerid, "\1");
	}
	
	if(PlayerEnterWarFlag[playerid] && PlayerGetFlag[playerid] && FlagDrill){
		foreach(new i : Player){
			if(!LoggedIn[i]) continue;
			if(!PlayerEnterWarFlag[i]) continue;
			SendClientMessageEx(i, 0xFF8300FF, "[ÇÍŞÔ§¸§]: ĽŮéŕĹčą %s ä´é·ÓˇŇĂÍÍˇ¨ŇˇĂĐşş¨Ö§·ÓăËé¸§µˇÍŐˇ¤ĂŃé§...", ReturnRoleplayName(playerid));
		} 

		new Float:x, Float:y, Float:z;
		GetPlayerPos(playerid, x, y, z);
		if(IsValidPickup(FlagPickup) && FlagPickup != -1) DestroyPickup(FlagPickup);
		FlagPickup = -1;
		FlagPickup = CreatePickup(2614, 2, x, y, z, 1);
		FlagDrill = false;
		PlayerGetFlag[playerid] = false;
		RemoveAttachedObject(playerid, 8);

		SvMutePlayerDisable(playerid);
	    PlayerData[playerid][pMicMute] = 0;
	}

	LoggedIn[playerid] = false;
	SetPlayerColor(playerid, 0xD6F8FFAA);
	TogglePlayerSpectating(playerid, 1);

	if(Jdz_Hunger_Bar_Show[playerid] && Jdz_Water_Bar_Show[playerid] && Jdz_Stamina_Bar_Show[playerid] && Jdz_Shower_Bar_Show[playerid] && Jdz_Stress_Bar_Show[playerid]){
		Jdz_Hunger_Hide(playerid);
		Jdz_Water_Hide(playerid);
		Jdz_Stamina_Hide(playerid);
		Jdz_Shower_Hide(playerid);
		Jdz_Stress_Hide(playerid);
	}

	if(Jdz_Exp_Show[playerid]){
		Jdz_Exp_Hud_Hide(playerid);
	}

	if(PlayerCarryAirDrop[playerid] != -1 && !IsPlayerNPC(playerid)){
        AirDrop_Spawn(playerid, PlayerCarryAirDrop[playerid]);
        SendClientMessageToAllEx(COLOR_ORANGE, "| ˘łĐąŐé AirDrop ˇĹčÍ§·Őč %d ä´éµˇáĹéÇ...", PlayerCarryAirDrop[playerid]);
        RemoveAttachedObject(playerid, 9);
		PlayerStartTimeAirDrop[playerid] = false;
        PlayerTextDrawHide(playerid, AirDropTimeTextDraw[playerid][0]);
        PlayerTextDrawDestroy(playerid, AirDropTimeTextDraw[playerid][0]);
		foreach(new i : Player) if(LoggedIn[i]){
            if(PlayerTrackAirDropPlayerID[i] == playerid){
				DisablePlayerCheckpoint(i);
                SendClientMessageEx(i, COLOR_ORANGERED, "| ĽŮéŕĹčą %s(%d) ·Őč¶×ÍˇĹčÍ§ AirDrop ˇĹčÍ§·Őč %d ÍÂŮčä´é ÍÍˇ¨ŇˇŕˇÁŕĂŐÂşĂéÍÂáĹéÇ", ReturnRoleplayName(playerid), playerid, PlayerCarryAirDrop[playerid]);
                PlayerTrackAirDropPlayerID[i] = INVALID_PLAYER_ID;
            }
        }
        PlayerCarryAirDrop[playerid] = -1;
    }

	CallLocalFunction("Character_Reset", "i", playerid);

	CallLocalFunction("Characters_Fetch", "i", playerid);
	DisablePlayerCheckpoint(playerid);

	PlayerTogSpeaker[playerid] = 0;
	HidePlayerProgressBar(playerid, SpeakerProgressBar[playerid][0]);
	DestroyPlayerProgressBar(playerid, SpeakerProgressBar[playerid][0]);

	printf("%s: Logout", AccountData[playerid][uName]);
	SetTimerEx("ChangeNameToUsername", 100, false, "i", playerid);
	return 1;
}

