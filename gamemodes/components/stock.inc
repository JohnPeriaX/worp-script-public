					PlayerData[playerid][pVipDay] = Day+viptime;
					PlayerData[playerid][pVipMonth] = Month;
					PlayerData[playerid][pVipHour] = Hour;
				}
			} 
			else if(Month == 4 || Month == 6 || Month == 9 || Month == 11){
				TotalDay = 30;
				if(Day+viptime > 30){
					if(Month + 1 > 12){
						Month = 1;
					}
					else{
						Month++;
					}
					ActualDay = viptime - (TotalDay-Day);
