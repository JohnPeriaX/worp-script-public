ResetWeapon(playerid){
	ResetPlayerWeapons(playerid);
	if (!BitFlag_Get(g_PlayerFlags[playerid], PLAYER_ONDUTY)){
		if (PlayerData[playerid][pMyWeapon][0] != 0){
			if(PlayerData[playerid][pMyAmmo][0] == 0) SetPlayerObjectWeapon(playerid, PlayerData[playerid][pMyWeapon][0]);
			else GivePlayerWeapon(playerid, PlayerData[playerid][pMyWeapon][0], PlayerData[playerid][pMyAmmo][0]);
		}

		if (PlayerData[playerid][pMyWeapon][1] != 0){
			if(PlayerData[playerid][pMyAmmo][1] == 0) SetPlayerObjectWeapon(playerid, PlayerData[playerid][pMyWeapon][1]);
			else GivePlayerWeapon(playerid, PlayerData[playerid][pMyWeapon][1], PlayerData[playerid][pMyAmmo][1]);
		}
		
		if (PlayerData[playerid][pMyWeapon][2] != 0){
	  		GivePlayerWeapon(playerid, PlayerData[playerid][pMyWeapon][2], PlayerData[playerid][pMyAmmo][2]);
		}
	}
	else{
		if(PlayerData[playerid][pMyWeapon][0] != 0){
			PlayerData[playerid][pDelayWeapon][0] = 0; 
			OnPlayerStoreWeapon1(playerid, PlayerData[playerid][pMyWeapon][0]);
		}

		if(PlayerData[playerid][pMyWeapon][1] != 0){
			PlayerData[playerid][pDelayWeapon][1] = 0; 
			OnPlayerStoreWeapon2(playerid, PlayerData[playerid][pMyWeapon][1]);
		}

		if(PlayerData[playerid][pMyWeapon][2] != 0){
			PlayerData[playerid][pDelayWeapon][2] = 0; 
			OnPlayerStoreWeapon3(playerid, PlayerData[playerid][pMyWeapon][2]);
		}
	}
	return 1;
}

