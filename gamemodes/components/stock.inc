stock GetVehicleFromBehind(vehicleid)
{
	new
	    Float:fCoords[7];

	GetVehiclePos(vehicleid, fCoords[0], fCoords[1], fCoords[2]);
	GetVehicleZAngle(vehicleid, fCoords[3]);

	for (new i = 1; i != MAX_VEHICLES; i ++) if (i != INVALID_VEHICLE_ID && i != vehicleid && GetVehiclePos(i, fCoords[4], fCoords[5], fCoords[6])){
		if (floatabs(fCoords[0] - fCoords[4]) < 4 && floatabs(fCoords[1] - fCoords[5]) < 4 && floatabs(fCoords[2] - fCoords[6]) < 4)
			return i;
	}
	return INVALID_VEHICLE_ID;
}

