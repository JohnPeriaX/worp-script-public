CheckPatternTime(const time[]){
	new Regex:r = Regex_New("[0-9]{2}:[0-9]{2}");
    new check = Regex_Check(time, r);
    Regex_Delete(r);
	return check;
}

IsValidRpName(const nickname[]){
    new Regex:r = Regex_New("([A-Z]{1,1})[a-z]{2,10}_([A-Z]{1,1})[a-z]{2,10}");
    new check = Regex_Check(nickname, r);
    Regex_Delete(r);
    return check;
}

