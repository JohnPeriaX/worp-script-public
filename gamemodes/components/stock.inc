stock RespawnVehicle(vehicleid){
	if(vehicleid != INVALID_VEHICLE_ID){
		new id = Car_GetID(vehicleid);
		if (id != -1){
			if(IsTrailerAttachedToVehicle(CarData[id][carVehicle])) return 1;
			if(CarData[id][carOwner] == 0){
				CarData[id][carFuel] = 100;
				ResetVehicle(CarData[id][carVehicle]);
				ResetVehicleDamage(CarData[id][carVehicle]);
				SetVehicleToRespawn(CarData[id][carVehicle]);
			}
			else{
				if(CarData[id][carInsideGarage] == 0){
					CarData[id][carInsideGarage] = 1;
					Car_Save(id);
					TRP_DestroyVehicle(CarData[id][carVehicle], true);
					CarData[id][carVehicle] = INVALID_VEHICLE_ID;
				}
			}
		}
		else {
			if(vehicleid == BusRed) return 1;
			if(vehicleid == BusYellow) return 1;
			if(IsTrailerAttachedToVehicle(vehicleid)) return 1;
			ResetVehicle(vehicleid);
			SetVehicleToRespawn(vehicleid);
		}
	}
	return 1;
}

stock IsVehicleEmpty(vehicleid){
    foreach (new i : Player){
		if(!LoggedIn[i]) continue;
		if(IsPlayerInVehicle(i, vehicleid)) return 1;
    }
    return 0;
}

