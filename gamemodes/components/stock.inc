Dialog:DialogVipShop(playerid, response, listitem, inputtext[]){
	if(!response) return 1;
	if(response){

		if(PlayerData[playerid][pVip] != 0)
			return ErrorMsg(playerid, "¤ŘłÂŃ§ŕ»çąĘÁŇŞÔˇ Vip ÍÂŮčäÁčĘŇÁŇĂ¶«×éÍä´é");

