			if(AccountData[playerid][uWallet] < 100) return ErrorMsg(playerid, "¤ŘłÁŐ Wallet äÁčľÍ");
			AccountData[playerid][uWallet] -= 100;
			UpdatePlayerWallet(playerid);
			new Year, Month, Day;
			new Hour, Minute, Second;
			gettime(Hour, Minute, Second);
			getdate(Year, Month, Day);
			new viptime = 30, TotalDay = 0, ActualDay;
			if(Month == 1 || Month == 3 || Month == 5 || Month == 7 || Month == 8 || Month == 10 || Month == 12){
				TotalDay = 31;
				if(Day+viptime > 31){
					if(Month + 1 > 12){
						Month = 1;
					}
					else{
						Month++;
					}
					
					ActualDay = viptime - (TotalDay-Day);
					if(ActualDay == 0) ActualDay = 1;

					if(Month == 2){
						if(ActualDay >= 29){
							if(ActualDay == 29) ActualDay = 1;
							else if(ActualDay == 30) ActualDay = 2;
							Month++;
							PlayerData[playerid][pVipDay] = ActualDay;
							PlayerData[playerid][pVipMonth] = Month;
							PlayerData[playerid][pVipHour] = Hour;
						}
						else{
							PlayerData[playerid][pVipDay] = ActualDay;
							PlayerData[playerid][pVipMonth] = Month;
							PlayerData[playerid][pVipHour] = Hour;
						}
					}
					else if(Month == 3){
						ActualDay = viptime - (TotalDay-Day);
						PlayerData[playerid][pVipDay] = ActualDay;
						PlayerData[playerid][pVipMonth] = Month;
						PlayerData[playerid][pVipHour] = Hour;
					}
					else{
						PlayerData[playerid][pVipDay] = ActualDay;
						PlayerData[playerid][pVipMonth] = Month;
						PlayerData[playerid][pVipHour] = Hour;
					}
