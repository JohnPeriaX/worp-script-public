SetPlayerStartDeliverBox(playerid){
    if(StartDeliverBox[playerid] == 0 && GotoSendBox[playerid] == 0){
        if(PlayerData[playerid][pJail] != 0){
            StartDeliverBox[playerid] = 1;
            ClearAnimations(playerid);
            ApplyAnimation(playerid, "CARRY", "liftup", 4.1, 0, 0, 0, 0, 0, 1);
            SetTimerEx("SetBoxOnHand", 1000, false, "i", playerid);
            SetPlayerSpecialAction(playerid, SPECIAL_ACTION_CARRY);
            new idx = GetClosestSideJobPoint(playerid, 3);
